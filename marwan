<script>
    // Logic for Navigation and Progress
    let currentSlide = 0;
    const slides = document.querySelectorAll('.slide');
    const progressFill = document.getElementById('progressFill');
    const totalSlides = slides.length; 

    document.getElementById('slideCounter').innerText = '1 / ' + totalSlides;
    document.getElementById('gotoSlide').setAttribute('max', totalSlides);

    function updateSlideCounter() {
        document.getElementById('slideCounter').innerText = (currentSlide + 1) + ' / ' + totalSlides;
        document.getElementById('gotoSlide').value = currentSlide + 1;
    }

    function goToSlide() {
        let slideNum = parseInt(document.getElementById('gotoSlide').value);
        if (slideNum >= 1 && slideNum <= totalSlides) {
            currentSlide = slideNum - 1;
            updateSlides();
            updateSlideCounter();
        } else {
            alert('رقم الشريحة من 1 إلى ' + totalSlides);
        }
    }

    function updateSlides() {
        slides.forEach((slide, idx) => {
            slide.classList.remove('active', 'prev');
            if (idx === currentSlide) {
                slide.classList.add('active');
            } else if (idx < currentSlide) {
                slide.classList.add('prev');
            }
        });
        const percent = ((currentSlide + 1) / totalSlides) * 100;
        progressFill.style.width = percent + '%';
        updateSlideCounter();
    }

    window.nextSlide = () => {
        if (currentSlide < totalSlides - 1) {
            currentSlide++;
            updateSlides();
        }
    };

    window.prevSlide = () => {
        if (currentSlide > 0) {
            currentSlide--;
            updateSlides();
        }
    };

    document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') nextSlide();
        else if (e.key === 'ArrowRight' || e.key === 'ArrowUp') prevSlide();
    });

    document.addEventListener('click', (e) => {
        if (e.target.closest('.btn-nav') || e.target.closest('#draggableControls')) return;
        const x = e.clientX;
        if (x < window.innerWidth * 0.3) nextSlide();
        else if (x > window.innerWidth * 0.7) prevSlide();
    });

    updateSlides();

    // Drag and Drop Logic for Controls
    const draggableMenu = document.getElementById('draggableControls');
    let isDragging = false;
    let startX, startY;

    draggableMenu.addEventListener('mousedown', dragStart);
    document.addEventListener('mousemove', dragMove);
    document.addEventListener('mouseup', dragEnd);

    draggableMenu.addEventListener('touchstart', dragStart, {passive: false});
    document.addEventListener('touchmove', dragMove, {passive: false});
    document.addEventListener('touchend', dragEnd);

    function dragStart(e) {
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'BUTTON' || e.target.closest('button')) return;
        isDragging = true;
        draggableMenu.classList.add('dragging');
        let clientX = e.clientX || (e.touches && e.touches[0].clientX);
        let clientY = e.clientY || (e.touches && e.touches[0].clientY);
        startX = clientX;
        startY = clientY;
        const rect = draggableMenu.getBoundingClientRect();
        draggableMenu.style.transform = 'none'; 
        draggableMenu.style.bottom = 'auto'; 
        draggableMenu.style.left = rect.left + 'px';
        draggableMenu.style.top = rect.top + 'px';
    }

    function dragMove(e) {
        if (!isDragging) return;
        e.preventDefault();
        let clientX = e.clientX || (e.touches && e.touches[0].clientX);
        let clientY = e.clientY || (e.touches && e.touches[0].clientY);
        let dx = clientX - startX;
        let dy = clientY - startY;
        let currentLeft = parseInt(draggableMenu.style.left) || 0;
        let currentTop = parseInt(draggableMenu.style.top) || 0;
        draggableMenu.style.left = (currentLeft + dx) + 'px';
        draggableMenu.style.top = (currentTop + dy) + 'px';
        startX = clientX;
        startY = clientY;
    }

    function dragEnd() {
        isDragging = false;
        draggableMenu.classList.remove('dragging');
    }
</script>
